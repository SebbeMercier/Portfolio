# Supabase Configuration
REACT_APP_SUPABASE_URL=your_supabase_project_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# Variables pour Node.js (scripts)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin Configuration
REACT_APP_ALLOWED_EMAILS=your_email@example.com

# Cloudflare Turnstile (optionnel)
REACT_APP_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Translation Services (optionnel - par ordre de priorité)
# DeepL API (recommandé - très précis, 500k chars/mois gratuit)
REACT_APP_DEEPL_API_KEY=your_deepl_api_key
REACT_APP_DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Google Translate API (payant mais précis)
REACT_APP_GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key

# LibreTranslate (gratuit, utilisé en fallback)
REACT_APP_LIBRETRANSLATE_URL=https://libretranslate.de

# Azure Translator (Microsoft - très bon aussi)
REACT_APP_AZURE_TRANSLATOR_KEY=your_azure_key
REACT_APP_AZURE_TRANSLATOR_REGION=your_region

# ⚠️  IMPORTANT: 
# 1. Copiez ce fichier vers .env
# 2. Remplacez les valeurs par vos vraies clés
# 3. Ne commitez JAMAIS le fichier .env
# 4. Les services de traduction sont optionnels - le système fonctionne sans clé API